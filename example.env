# OpenRouter API Configuration
OPENROUTER_API_KEY=#YOUR_OPENROUTER_API_KEY# Replace with your actual OpenRouter API key
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
APP_URL=http://localhost:8000
APP_TITLE=HK Agent Demo

# LangSmith Tracing Configuration
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=#YOUR_LANGSMITH_API_KEY# Replace with your actual LangSmith API key
LANGSMITH_PROJECT=langchainexample
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
